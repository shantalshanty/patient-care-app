<%- include('partials/header') %>

<div class="hero-section">
    <div class="container">
        <div class="row align-items-center min-vh-100">
            <div class="col-lg-6">
                <span class="badge-soft mb-3">Smart Healthcare Platform</span>
                <h1 class="hero-title">Patient Care System</h1>
                <p class="hero-text">
                    A modern healthcare web application for managing patient records,
                    appointments, and secure access in one place.
                </p>

                <div class="mt-4">
                    <a href="/register" class="btn btn-primary btn-lg me-3">Get Started</a>
                    <a href="/login" class="btn btn-outline-primary btn-lg">Login</a>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="hero-card">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="mini-card">
                                <div class="icon-circle"><i class="bi bi-person-plus"></i></div>
                                <h5>Patient Profiles</h5>
                                <p>Register and manage patient information securely.</p>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="mini-card">
                                <div class="icon-circle"><i class="bi bi-calendar-check"></i></div>
                                <h5>Appointments</h5>
                                <p>Book and track appointments with ease.</p>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="mini-card">
                                <div class="icon-circle"><i class="bi bi-shield-lock"></i></div>
                                <h5>Secure Access</h5>
                                <p>Role-based authentication for safer access control.</p>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="mini-card">
                                <div class="icon-circle"><i class="bi bi-clipboard2-pulse"></i></div>
                                <h5>Care Dashboard</h5>
                                <p>Clean and simple interface for healthcare workflows.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="py-5">
            <div class="text-center mb-5">
                <h2 class="section-title">Core Features</h2>
                <p class="section-text">Built to demonstrate practical healthcare workflow management.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card">
                        <i class="bi bi-person-badge feature-icon"></i>
                        <h4>Patient Management</h4>
                        <p>Create patient accounts and manage access securely through the platform.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card">
                        <i class="bi bi-calendar2-week feature-icon"></i>
                        <h4>Appointment Booking</h4>
                        <p>Allow patients to book appointments and doctors to review them easily.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card">
                        <i class="bi bi-lock feature-icon"></i>
                        <h4>Role-Based Security</h4>
                        <p>Protect routes using JWT authentication and authorization middleware.</p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<%- include('partials/footer') %>