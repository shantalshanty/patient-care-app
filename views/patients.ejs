<%- include('partials/header') %>
<%- include('partials/navbar', { user: user }) %>

<div class="dashboard-wrapper">
    <div class="container py-5">

        <div class="dashboard-header mb-4">
            <div>
                <h2 class="dashboard-title">Patient Records</h2>
                <p class="dashboard-subtitle">
                    View all registered patients and their appointment activity.
                </p>
            </div>
        </div>

        <div class="main-card p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">All Patients</h4>
                <span class="table-count"><%= patients.length %> patients</span>
            </div>

            <div class="table-responsive">
                <table class="table custom-table align-middle">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Appointments</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (patients.length === 0) { %>
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No patients found.
                                </td>
                            </tr>
                        <% } %>

                        <% patients.forEach(patient => { %>
                            <tr>
                                <td>
                                    <div class="table-user">
                                        <div class="table-user-icon">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        <div class="fw-semibold"><%= patient.name %></div>
                                    </div>
                                </td>
                                <td><%= patient.email %></td>
                                <td>
                                    <span class="status-badge status-approved"><%= patient.role %></span>
                                </td>
                                <td><%= patient.appointmentCount %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<%- include('partials/footer') %>