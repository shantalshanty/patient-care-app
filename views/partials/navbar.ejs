<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <h3>🏥 PatientCare</h3>
        </div>

        <nav class="sidebar-nav">
            <a href="/dashboard" class="sidebar-link">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard
            </a>

            <a href="/appointments" class="sidebar-link">
                <i class="bi bi-calendar-check me-2"></i> Appointments
            </a>

            <% if (user && user.role === 'doctor') { %>
                <a href="/doctor" class="sidebar-link">
                    <i class="bi bi-hospital me-2"></i> Doctor Panel
                </a>

                <a href="/patients" class="sidebar-link">
                    <i class="bi bi-people me-2"></i> Patient Records
                </a>
            <% } %>

            <% if (user && user.role === 'patient') { %>
               <a href="/triage" class="sidebar-link">
               <i class="bi bi-chat-dots me-2"></i> Triage Assistant
               </a>

               <a href="/triage-history" class="sidebar-link">
               <i class="bi bi-clock-history me-2"></i> My Triage
               </a>
            <% } %>

            <% if (user && user.role === 'doctor') { %>
               <a href="/doctor-triage" class="sidebar-link">
               <i class="bi bi-clipboard2-pulse me-2"></i> Triage Review
               </a>
            <% } %>

            <a href="/logout" class="sidebar-link logout-link">
                <i class="bi bi-box-arrow-right me-2"></i> Logout
            </a>
        </nav>
    </aside>

    <main class="main-content">